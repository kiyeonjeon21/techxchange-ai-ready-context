# Copy to `.env` and fill in your own values. `.env` is gitignored — never commit real secrets.
#
# The RAG YAMLs (integrations/rag/*.yaml) and dbt profiles contain placeholders that you must
# substitute with your own cluster values before `oc apply` / `dbt run`:
#   <CLUSTER_DOMAIN>    e.g. apps wildcard domain of your OpenShift cluster (xxxx.containers.cloud.ibm.com)
#   <CLUSTER_NAME>      your cluster's short name
#   <WX_PROJECT_ID>     watsonx.ai project GUID
#   <ASTRA_HOST>        https://<db-id>-<region>.apps.astra.datastax.com
#   <PRESTO_HOST>       watsonx.data Presto engine route host (…-presto-svc.apps.<CLUSTER_DOMAIN>)
#   <PRESTO_ENGINE>     watsonx.data Presto engine instance name
#   <WXD_INSTANCE_ID>   watsonx.data instance id

# ---- OpenShift cluster ----
OCP_CONSOLE_URL=https://console-openshift-console.apps.<CLUSTER_DOMAIN>
OCP_API_URL=
BASTION_CONNECTION=
BASTION_PASSWORD=
CLUSTER_ADMIN_USERNAME=
CLUSTER_ADMIN_PASSWORD=
OCP_VERSION=4.18
CPD_VERSION=5.3.1
IBM_ENTITLEMENT_KEY=

# ---- watsonx.data / CPD (Software Hub) ----
CPD_CONSOLE_URL=
WXD_CONSOLE_URL=
WXD_INSTANCE_ID=
CPD_ADMIN_USERNAME=
CPD_ADMIN_PASSWORD=
WXD_API_KEY=

# ---- watsonx.ai (SaaS) ----
WX_APIKEY=
WX_URL=https://us-south.ml.cloud.ibm.com
WX_PROJECT_ID=

# ---- AstraDB (DataStax SaaS, non-vector NoSQL — KG store) ----
ASTRA_HOST=
ASTRA_CLIENTID=
ASTRA_SECRET=
ASTRA_TOKEN=

# ---- Langflow (optional) ----
LANGFLOW_APIKEY=
