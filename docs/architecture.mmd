---
title: Agentic RAG + Knowledge Graph on OpenShift — watsonx.data · watsonx.ai · Langflow · Docling
---
flowchart TB
  user(["User"])

  subgraph OCP["OpenShift cluster (&lt;CLUSTER_NAME&gt;)"]
    subgraph GENAI["ns: genai-apps"]
      chat["rag-ui — Chat UI · /api/chat<br/>answer · citations · tool-trace · evidence"]
      langflow{"Langflow Agent — IBM open source<br/>orchestration · tool-calling — MAIN"}
      pyagent{"Python agent<br/>router · synth — fallback"}
      subgraph TOOLS["Retrieval tools — rag-ui /api/tool/* (token-gated)"]
        tvec["Vector search<br/>hybrid kNN + BM25"]
        tkg["Graph lookup<br/>embedding seed → 1-hop"]
        tsql["text-to-SQL<br/>guarded SELECT + self-correction"]
      end
      subgraph INGEST["Ingestion"]
        src[/"Documents<br/>text · URL · PDF"/] --> docling["docling-serve<br/>IBM open source"]
        kgx["KG extract<br/>LLM + entity resolution + ontology"]
        seed["seed_aml.py<br/>AML demo dataset"]
      end
      ops["docling-graph (optional)<br/>CronJob rag-reindex */30"]
    end
    subgraph WXD["ns: cpd — IBM watsonx.data (Software Hub, in-cluster)"]
      os[("OpenSearch<br/>kNN lucene dim768 + BM25")]
      iceberg[("Iceberg<br/>rag.corpus · aml.*")]
      presto["Presto (PrestoDB)"]
      spark["Spark engine"]
      minio[("MinIO object storage")]
    end
  end

  subgraph MANAGED["IBM watsonx — managed cloud / SaaS"]
    wxai["watsonx.ai · granite<br/>chat (4-h-small · 3-8b) + embed-278m"]
    astra[("DataStax AstraDB<br/>IBM watsonx.data (managed) — KG")]
  end

  %% ---- query (read): Chat UI delegates to Langflow, Python agent is the fallback ----
  user --> chat
  chat ==>|main| langflow
  chat -. fallback .-> pyagent
  langflow ==> TOOLS
  pyagent -.-> TOOLS
  tvec --> os
  tkg --> astra
  tsql --> presto --> iceberg
  langflow <-. granite generate .-> wxai

  %% ---- ingestion (write) ----
  docling -->|chunks + embed| os
  docling --> kgx --> astra
  docling -->|inventory| iceberg
  seed --> iceberg
  docling -. embed / extract .-> wxai
  iceberg <--> minio
  spark -. batch .-> iceberg
  ops -. maintain .-> docling

  classDef ibm fill:#dbeafe,stroke:#0f62fe,color:#111
  classDef ibmoss fill:#d7f5ee,stroke:#0a9396,color:#111
  classDef store fill:#fff4e5,stroke:#f5a623,color:#111
  classDef app fill:#ede7ff,stroke:#7c5cff,color:#111
  class wxai ibm
  class langflow,docling ibmoss
  class os,iceberg,minio,astra store
  class chat,tvec,tkg,tsql,pyagent,kgx,seed,ops,presto,spark app
  style WXD fill:#eef4ff,stroke:#0f62fe,stroke-width:2px
  style MANAGED fill:#eef4ff,stroke:#0f62fe,stroke-width:1px
