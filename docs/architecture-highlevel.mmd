---
title: Agentic RAG + Knowledge Graph — High-Level
---
flowchart LR
  user(["User"])

  subgraph ING["Ingestion"]
    direction TB
    docs[/"Documents<br/>text · URL · PDF"/]
    docling["Docling<br/>IBM open source<br/>document parsing"]
    docs --> docling
  end

  subgraph APP["Chat UI — rag-ui (FastAPI, OpenShift)"]
    ui["Chat UI + API<br/>/api/chat → Langflow<br/>(fallback: in-process Python agent)"]
  end

  lf{"Langflow Agent<br/>IBM open source<br/>orchestration · tool-calling<br/>(watsonx granite)"}

  subgraph RET["Retrieval tools"]
    vec["Vector search<br/>(semantic)"]
    kg["Graph lookup<br/>(relationships)"]
    sql["SQL query<br/>(text-to-SQL)"]
  end

  subgraph WXD["IBM watsonx.data — data store + engine"]
    os[("OpenSearch<br/>vector + BM25")]
    ice[("Iceberg + Presto<br/>lakehouse SQL")]
    astra[("DataStax AstraDB<br/>knowledge graph (NoSQL)")]
  end

  wx["IBM watsonx.ai<br/>granite — embed + LLM"]

  %% ingest (write)
  docling -. ingest .-> ui

  %% query (read) — Chat UI delegates orchestration to the Langflow agent
  user --> ui --> lf
  lf --> vec --> os
  lf --> kg --> astra
  lf --> sql --> ice
  vec & kg & sql --> lf
  lf <-. embed + generate .-> wx
  lf --> ans(["Answer<br/>+ citations + evidence"]) --> user

  classDef ibm fill:#dbeafe,stroke:#0f62fe,color:#111
  classDef ibmoss fill:#d7f5ee,stroke:#0a9396,color:#111
  classDef store fill:#fff4e5,stroke:#f5a623,color:#111
  classDef app fill:#ede7ff,stroke:#7c5cff,color:#111
  class wx ibm
  class docling,lf ibmoss
  class os,ice,astra store
  class ui app
  style WXD fill:#eef4ff,stroke:#0f62fe,stroke-width:2px
